#include <iostream>
#include <vector>
#include <cmath>
using namespace std;
 
int main(){
    int n;
    cin>>n;
    while(n--){
        int n1;
        cin>>n1;
        long long sum = 0;
        vector <int> v(n1);
        for(int i = 0; i<n1; i++){
            cin>>v[i];
        }
        for(int i = 0; i<n1;i++){
            sum += v[i];
        } 
        long long p = sqrt(sum);
        if(p * p == sum){
            cout<<"YES"<<endl;
        }
        else{
            cout<<"NO"<<endl;
        }
    }
    return 0;
}